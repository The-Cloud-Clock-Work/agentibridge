# AgentiBridge — Environment Variables
# Copy to .env and customize for your deployment.

# =============================================================================
# REDIS
# =============================================================================
REDIS_URL=redis://redis:6379/0
REDIS_KEY_PREFIX=agentibridge

# =============================================================================
# POSTGRES (shared by agentibridge + postgres services)
# =============================================================================
POSTGRES_USER=agentibridge
POSTGRES_PASSWORD=agentibridge
POSTGRES_DB=agentibridge
POSTGRES_URL=postgresql://agentibridge:agentibridge@postgres:5432/agentibridge

# =============================================================================
# AGENTIBRIDGE
# =============================================================================

# Transport mode: "stdio" (local MCP) or "sse" (HTTP remote)
AGENTIBRIDGE_TRANSPORT=sse

# SSE/HTTP bind address and port
AGENTIBRIDGE_HOST=0.0.0.0
AGENTIBRIDGE_PORT=8100

# Comma-separated API keys for authentication (empty = no auth)
AGENTIBRIDGE_API_KEYS=

# Background collector poll interval (seconds)
AGENTIBRIDGE_POLL_INTERVAL=60

# Maximum entries per session in Redis (0 = unlimited)
AGENTIBRIDGE_MAX_ENTRIES=500

# Override Claude CLI transcript directory (default: ~/.claude/projects)
# AGENTIBRIDGE_PROJECTS_DIR=/home/appuser/.claude/projects

# =============================================================================
# LOGGING
# =============================================================================
CLAUDE_HOOK_LOG_ENABLED=true
AGENTIBRIDGE_LOG_FILE=/app/logs/agentibridge.log

# =============================================================================
# OAUTH 2.1 (optional — enables claude.ai remote MCP connection)
# =============================================================================
# Set OAUTH_ISSUER_URL to enable OAuth 2.1 (authorization_code + PKCE).
# Use your public-facing URL. API key auth continues working alongside OAuth.
# OAUTH_ISSUER_URL=https://homebridge.example.com
# OAUTH_RESOURCE_URL=                # Optional, defaults to {OAUTH_ISSUER_URL}/mcp
#
# Pre-configured client credentials (recommended for production).
# Set both to lock down the server — only this client can authenticate.
# Enter the same values in claude.ai's "OAuth Client ID/Secret" fields.
# When unset, dynamic client registration is open (anyone can register).
# OAUTH_CLIENT_ID=my-bridge-client
# OAUTH_CLIENT_SECRET=generate-a-strong-secret-here
#
# Comma-separated allowed redirect URIs for the pre-configured client.
# Each MCP client has its own callback URL (e.g. claude.ai uses theirs).
# OAUTH_ALLOWED_REDIRECT_URIS=https://claude.ai/api/mcp/auth_callback
#
# Space-separated OAuth scopes the client is allowed to request.
# Claude.ai requests "claudeai". Leave empty to reject all scope requests.
# OAUTH_ALLOWED_SCOPES=claudeai

# =============================================================================
# SEMANTIC SEARCH + SUMMARIES (Phase 2 — optional)
# =============================================================================
# OpenAI-compatible API (works with OpenRouter, LiteLLM, OpenAI, etc.)
# LLM_API_BASE=https://openrouter.ai/api/v1
# LLM_API_KEY=
# LLM_EMBED_MODEL=text-embedding-3-small
# LLM_CHAT_MODEL=anthropic/claude-sonnet-4-5

# Alternatively: Anthropic SDK for summaries (set ANTHROPIC_API_KEY)
# ANTHROPIC_API_KEY=

# =============================================================================
# TASK DISPATCH (Phase 4 — uses Claude CLI directly)
# =============================================================================
# CLAUDE_BINARY=claude
# CLAUDE_DISPATCH_MODEL=sonnet
# CLAUDE_DISPATCH_TIMEOUT=300

# =============================================================================
# DOCKER COMPOSE
# =============================================================================
# Override host path for .claude mount (default: ~/.claude)
# Set to bridge-smoke-dataset/.claude path for CI testing
# CLAUDE_DIR=~/.claude

# =============================================================================
# CLOUDFLARE TUNNEL (optional — use --profile tunnel)
# =============================================================================
# For named tunnels (persistent hostname):
# CLOUDFLARE_TUNNEL_TOKEN=your-tunnel-token-here
#
# Leave unset for quick tunnels (temporary *.trycloudflare.com URL).

# =============================================================================
# CLOUDFLARE ACCESS (optional — when LLM backend is behind Cloudflare Access)
# =============================================================================
# If your LLM API (LiteLLM, OpenRouter proxy, etc.) is protected by Cloudflare
# Access, set these service-token credentials so AgentiBridge can reach it.
# These are NOT related to the tunnel — they cover outbound LLM API requests.
# Get values from: Zero Trust Dashboard → Access > Service Auth > Service Tokens
# CF_ACCESS_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.access
# CF_ACCESS_CLIENT_SECRET=yyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyy
