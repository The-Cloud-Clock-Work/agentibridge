# Agentic Bridge — Environment Variables
# Copy to .env and customize for your deployment.

# =============================================================================
# REDIS
# =============================================================================
REDIS_URL=redis://redis:6379/0
REDIS_KEY_PREFIX=agenticore

# =============================================================================
# SESSION BRIDGE
# =============================================================================

# Transport mode: "stdio" (local MCP) or "sse" (HTTP remote)
SESSION_BRIDGE_TRANSPORT=sse

# SSE/HTTP bind address and port
SESSION_BRIDGE_HOST=0.0.0.0
SESSION_BRIDGE_PORT=8100

# Comma-separated API keys for authentication (empty = no auth)
SESSION_BRIDGE_API_KEYS=

# Background collector poll interval (seconds)
SESSION_BRIDGE_POLL_INTERVAL=60

# Maximum entries per session in Redis (0 = unlimited)
SESSION_BRIDGE_MAX_ENTRIES=500

# Override Claude CLI transcript directory (default: ~/.claude/projects)
# SESSION_BRIDGE_PROJECTS_DIR=/home/appuser/.claude/projects

# =============================================================================
# LOGGING
# =============================================================================
CLAUDE_HOOK_LOG_ENABLED=true
AGENTIC_BRIDGE_LOG_FILE=/app/logs/agentic-bridge.log

# =============================================================================
# SEMANTIC SEARCH (Phase 2 — optional)
# =============================================================================
# SESSION_BRIDGE_EMBEDDING_ENABLED=false
# EMBEDDING_BACKEND=bedrock
# ANTHROPIC_API_KEY=

# =============================================================================
# TASK DISPATCH (Phase 4 — optional)
# =============================================================================
# AGENT_API_ENDPOINT=http://localhost:8000
# AGENT_API_KEY=
# AGENT_API_TIMEOUT=300

# =============================================================================
# DOCKER COMPOSE
# =============================================================================
# Override host path for transcript mount
# CLAUDE_PROJECTS_DIR=~/.claude/projects
