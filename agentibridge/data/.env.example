# AgentiBridge — Native Mode Configuration
# Auto-created at ~/.agentibridge/.env on first run.
# Edit this file to persist your settings across sessions.
#
# This file is for NATIVE MODE (`python -m agentibridge`).
# Docker mode uses a separate file: ~/.agentibridge/docker.env
# (auto-created on first `agentibridge run`).
#
# Config resolution order (first found wins, explicit env vars always override):
#   1. Explicit env vars (already set in shell/process)
#   2. Project-local .env (current working directory)
#   3. ~/.agentibridge/.env (this file)
#
# =============================================================================
# HOW AGENTIBRIDGE RUNS
# =============================================================================
#
# There are two ways to run AgentiBridge, each with its own config file:
#
#   1. DOCKER MODE — `agentibridge run`
#      Config: ~/.agentibridge/docker.env
#      Starts 3 containers: agentibridge + Redis + Postgres.
#      Redis and Postgres are bundled — you don't need to configure them.
#      The Docker compose stack sets REDIS_URL, POSTGRES_URL, and
#      AGENTIBRIDGE_TRANSPORT=sse automatically in docker.env.
#
#   2. NATIVE MODE — `python -m agentibridge` (stdio)
#      Config: ~/.agentibridge/.env (this file)
#      Runs as a single Python process with no external services.
#      Without Redis, every tool call (list_sessions, search, etc.)
#      re-parses the raw JSONL files from ~/.claude/projects/ on disk.
#      This works but is slower — no caching, no incremental indexing.
#      To add Redis/Postgres to native mode, you must run them yourself
#      (e.g. `docker run redis` or a managed service) and set the URLs below.
#
# Both modes can run simultaneously without conflict.
#
# =============================================================================
# TOOL FILTERING
# =============================================================================

# Comma-separated list of tool names to remove from the server at startup.
# Use this to expose only a subset of tools (e.g., read-only tools in a
# shared environment). Empty = all tools enabled.
# AGENTIBRIDGE_REMOVE_TOOLS=dispatch_task,search_semantic

# =============================================================================
# TRANSPORT
# =============================================================================

# "stdio" — runs as an MCP subprocess (Claude Code spawns it via .mcp.json)
# "sse"   — runs as an HTTP server (for remote clients, claude.ai, etc.)
AGENTIBRIDGE_TRANSPORT=stdio

# =============================================================================
# COLLECTOR
# =============================================================================

# How often the background collector scans ~/.claude/projects/ for new
# transcript data (seconds). Lower = more responsive, higher = less CPU.
AGENTIBRIDGE_POLL_INTERVAL=60

# Maximum transcript entries to store per session in Redis (0 = unlimited).
# Only applies when Redis is connected. Ignored in filesystem-only mode.
AGENTIBRIDGE_MAX_ENTRIES=500

# =============================================================================
# LOGGING
# =============================================================================
CLAUDE_HOOK_LOG_ENABLED=true
# Log file auto-detects: /app/logs/agentibridge.log (Docker) or
# ~/.cache/agentibridge/agentibridge.log (native)

# =============================================================================
# STORAGE — Redis (optional)
# =============================================================================
# When REDIS_URL is set, AgentiBridge stores indexed sessions in Redis.
# The collector runs in the background, incrementally parsing new transcript
# entries and caching them. Tool calls (list_sessions, search, get_session)
# read from Redis — fast, with pagination and time-range filters.
#
# When REDIS_URL is NOT set (default for native mode), every tool call
# reads and parses the raw JSONL files from ~/.claude/projects/ directly.
# This works for small numbers of sessions but gets slower as you accumulate
# more transcripts.
#
# In Docker mode (`agentibridge run`), Redis is bundled — the compose stack
# sets REDIS_URL=redis://redis:6379/0 automatically. You don't need to
# uncomment these.
#
# In native mode, uncomment and point to your own Redis instance:
# REDIS_URL=redis://localhost:6379/0
# REDIS_KEY_PREFIX=agentibridge

# =============================================================================
# STORAGE — Postgres + pgvector (optional, for semantic search)
# =============================================================================
# Required for the `search_semantic` and `generate_summary` tools.
# Stores embedding vectors in Postgres with the pgvector extension.
# Without this, keyword search (`search_sessions`) still works.
#
# In Docker mode, Postgres is bundled (pgvector/pgvector:pg16 image).
# In native mode, uncomment and point to your own Postgres with pgvector:
#
# Master switch — off by default because it requires both a Postgres
# database and an LLM endpoint to be configured. Set to "true" only
# after filling in the variables below.
# AGENTIBRIDGE_EMBEDDING_ENABLED=false
#
# Where to store the embedding vectors. Needs the pgvector extension.
# POSTGRES_URL=postgresql://user:pass@localhost:5432/agentibridge
#
# Base URL of any OpenAI-compatible API (OpenRouter, LiteLLM, Ollama,
# OpenAI itself, etc.). AgentiBridge calls /embeddings and /chat/completions
# on this endpoint.
# LLM_API_BASE=https://openrouter.ai/api/v1
#
# Auth token for the LLM endpoint above. Not needed for local servers
# like Ollama that don't require authentication.
# LLM_API_KEY=
#
# Model used to turn transcript text into numeric vectors for similarity
# search. Must match the PGVECTOR_DIMENSIONS setting (default 1536).
# LLM_EMBED_MODEL=text-embedding-3-small
#
# The `generate_summary` MCP tool reads a session transcript and asks
# an LLM to produce a 2-3 sentence summary of what happened. It tries
# three backends in order:
#   1. Anthropic SDK  (if ANTHROPIC_API_KEY is set)
#   2. LLM_CHAT_MODEL (if LLM_API_BASE is set — any OpenAI-compatible chat model)
#   3. Claude CLI      (if the `claude` binary is on the host)
# You only need ONE of these. If none are configured, `generate_summary`
# returns an error — all other tools still work fine.
#
# Chat model for generating summaries via the generic LLM endpoint.
# LLM_CHAT_MODEL=anthropic/claude-sonnet-4-5
#
# Direct Anthropic SDK key — tried first, skipped if unset.
# Use ANTHROPIC_API_KEY for direct Anthropic API access.
# Use ANTHROPIC_AUTH_TOKEN + ANTHROPIC_BASE_URL for LLM proxies
# (LiteLLM, OpenRouter, custom gateways). The Anthropic SDK resolves
# both automatically — set whichever matches your setup.
# ANTHROPIC_API_KEY=
# ANTHROPIC_AUTH_TOKEN=
# ANTHROPIC_BASE_URL=

# =============================================================================
# SSE/HTTP REMOTE MODE
# =============================================================================
# Only used when AGENTIBRIDGE_TRANSPORT=sse.
# In stdio mode these are ignored.
#
# AGENTIBRIDGE_HOST=127.0.0.1
# AGENTIBRIDGE_PORT=8100
# AGENTIBRIDGE_API_KEYS=

# =============================================================================
# TASK DISPATCH (Claude CLI)
# =============================================================================
# Enables the `dispatch_task` tool — fire-and-forget background jobs.
# Requires the Claude CLI binary installed on the host.
#
CLAUDE_BINARY=claude
CLAUDE_DISPATCH_MODEL=sonnet
CLAUDE_DISPATCH_TIMEOUT=300

# Dispatch bridge (Docker mode only) — proxies dispatch_task from container
# to a host-side bridge. Set automatically in docker.env; uncomment here
# only if you want to use the bridge in native mode too.
# CLAUDE_DISPATCH_URL=http://host.docker.internal:8101
# DISPATCH_SECRET=changeme-generate-a-random-secret

# =============================================================================
# OAUTH 2.1 (optional — enables claude.ai remote MCP connection)
# =============================================================================
# Set OAUTH_ISSUER_URL to enable OAuth 2.1 (authorization_code + PKCE).
# Use your public-facing URL. API key auth continues working alongside OAuth.
# OAUTH_ISSUER_URL=https://homebridge.example.com
# OAUTH_RESOURCE_URL=                # Optional, defaults to {OAUTH_ISSUER_URL}/mcp
#
# Pre-configured client credentials (recommended for production).
# Set both to lock down the server — only this client can authenticate.
# Enter the same values in claude.ai's "OAuth Client ID/Secret" fields.
# When unset, dynamic client registration is open (anyone can register).
# OAUTH_CLIENT_ID=my-bridge-client
# OAUTH_CLIENT_SECRET=generate-a-strong-secret-here
#
# Comma-separated allowed redirect URIs for the pre-configured client.
# Each MCP client has its own callback URL (e.g. claude.ai uses theirs).
# OAUTH_ALLOWED_REDIRECT_URIS=https://claude.ai/api/mcp/auth_callback
#
# Space-separated OAuth scopes the client is allowed to request.
# Claude.ai requests "claudeai". Leave empty to reject all scope requests.
# OAUTH_ALLOWED_SCOPES=claudeai

# =============================================================================
# DOCKER COMPOSE (only relevant for `agentibridge run`)
# =============================================================================
# Override host path for .claude mount (default: ~/.claude).
# Useful when Claude transcripts live on a shared/network filesystem,
# a non-standard home directory, or a dedicated volume.
# CLAUDE_DIR=~/.claude

# =============================================================================
# CLOUDFLARE TUNNEL (optional — use --profile tunnel)
# =============================================================================
# For named tunnels (persistent hostname).
# This token is static — set it once and it works permanently across
# restarts, reboots, and redeployments. Only changes if you delete and
# recreate the tunnel in the Cloudflare Zero Trust dashboard.
# CLOUDFLARE_TUNNEL_TOKEN=your-tunnel-token-here
#
# Leave unset for quick tunnels (temporary *.trycloudflare.com URL).

# =============================================================================
# CLOUDFLARE ACCESS (optional — when LLM backend is behind Cloudflare Access)
# =============================================================================
# This section is NOT an AgentiBridge feature — it's for a specific deployment
# pattern where your LLM proxy (LiteLLM, OpenRouter, etc.) is protected by
# Cloudflare Access Zero Trust. AgentiBridge's author uses this setup: all LLM
# endpoints are behind Cloudflare Access, so AgentiBridge needs service-token
# credentials to make outbound API requests to them.
#
# If your LLM backend is NOT behind Cloudflare Access, ignore this section.
#
# These are NOT related to the Cloudflare Tunnel above — the tunnel handles
# inbound MCP connections, while these credentials handle outbound LLM requests.
#
# Get values from: Zero Trust Dashboard → Access > Service Auth > Service Tokens
# CF_ACCESS_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.access
# CF_ACCESS_CLIENT_SECRET=yyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyy
